{% extends 'base.html' %}

{% block content %}

<h2>RTS Close</h2>

<form method="POST">
    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">

    <label>Reason</label>

    <textarea
        name="reason"
        required>
    </textarea>

    <br><br>

    <button type="submit">
        Close Record
    </button>

</form>

{% endblock %}