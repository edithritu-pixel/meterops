table {
    width: 100%;
    border-collapse: collapse;
    background: white;
}

th {
    background: #1e293b;
    color: white;
    padding: 14px 12px;
    text-align: left;
    position: sticky;
    top: 0;
    z-index: 10;
    font-size: 14px;
}

td {
    padding: 10px 12px;
    font-size: 14px;
    line-height: 1.4;
    vertical-align: middle;
    border-bottom: 1px solid #e5e7eb;
}

/* Zebra rows */
tr:nth-child(even) {
    background: #f8fafc;
}

tr:nth-child(odd) {
    background: white;
}

/* Hover effect */
tr:hover {
    background: #eef2ff;
 }   
