/* =========================================
   REPORT FILTERS
========================================= */

.filter-form{
    display:flex;
    gap:12px;
    align-items:center;
    flex-wrap:wrap;
    margin-bottom:20px;
}

.filter-form label{
    font-weight:600;
    color:#374151;
}

.filter-form input,
.filter-form select{
    padding:10px 14px;
    border:1px solid #D1D5DB;
    border-radius:10px;
    background:white;
    min-width:140px;
}

.filter-form input:focus,
.filter-form select:focus{
    outline:none;
    border-color:#2563EB;
    box-shadow:0 0 0 3px rgba(37,99,235,.15);
}

.filter-form button{
    background:#2563EB;
    color:white;
    border:none;
    padding:10px 18px;
    border-radius:10px;
    font-weight:600;
    cursor:pointer;
}

.filter-form button:hover{
    background:#1D4ED8;
}

