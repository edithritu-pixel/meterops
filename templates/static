.roq-tabs {
    display: flex;
    gap: 14px;
    margin-bottom: 30px;
    flex-wrap: wrap;
    align-items: center;
}

.tab {
    display: flex;
    align-items: center;
    gap: 8px;

    text-decoration: none;

    padding: 12px 20px;

    background: #F3F4F6;

    color: #374151;

    border-radius: 14px;

    font-weight: 600;

    font-size: 15px;

    transition: all 0.2s ease;

    border: 1px solid transparent;
}

.tab:hover {
    background: #DBEAFE;
    color: #2563EB;
    transform: translateY(-1px);
}

.active-tab {
    background: #2563EB;
    color: white;

    box-shadow: 0 6px 16px rgba(37, 99, 235, 0.25);
}



.badge {
    min-width: 24px;
    height: 24px;

    display: flex;
    align-items: center;
    justify-content: center;

    padding: 0 8px;

    border-radius: 999px;

    background: #E5E7EB;

    font-size: 12px;

    font-weight: 700;
}

.danger-tab:hover {
    background: #FEE2E2;
    color: #DC2626;
}

.gray-tab:hover {
    background: #E5E7EB;
    color: #4B5563;
}
.badge {
    background: white;
    color: #2563EB;
    padding: 2px 8px;
    border-radius: 999px;
    margin-left: 8px;
    font-size: 12px;

}
tr:hover {
    background: #F9FAFB;
}
/* =========================================
   REPORTS
========================================= */

.report-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-top: 20px;
}

.report-card {
    background: white;
    padding: 24px;
    border-radius: 16px;
    border: 1px solid #E5E7EB;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.report-card h3 {
    margin-top: 0;
    margin-bottom: 10px;
    color: #1F2937;
}

.report-card p {
    color: #6B7280;
    margin-bottom: 15px;
}

